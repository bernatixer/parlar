# WorkOS AuthKit — leave WORKOS_CLIENT_ID blank to use the local mock auth provider.
# Get these from https://dashboard.workos.com → Applications → AuthKit.
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_REDIRECT_URI=http://localhost:5173/api/auth/callback
# Generate with: openssl rand -base64 32  (must be 32+ chars)
WORKOS_COOKIE_PASSWORD=
